{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out/test",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "mocha", "vscode"],
    "sourceMap": true
  },
  "include": [
    "tests/integration/**/*.ts",
    "tests/helpers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/e2e/**/*.ts",
    "tests/*.test.ts"
  ]
}
