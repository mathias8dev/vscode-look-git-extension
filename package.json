{
  "name": "look-git",
  "displayName": "Look Git",
  "description": "Advanced Git operations: cherry-pick, rebase, reset, revert, drop, and rename commits",
  "version": "0.0.1",
  "publisher": "mathias8dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "cherry-pick",
    "rebase",
    "reset",
    "revert",
    "interactive rebase"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [],
  "contributes": {
    "submenus": [
      { "id": "lookGit.changesView.commit", "label": "Commit" },
      { "id": "lookGit.changesView.changes", "label": "Changes" },
      { "id": "lookGit.changesView.pullPush", "label": "Pull, Push" },
      { "id": "lookGit.changesView.branch", "label": "Branch" },
      { "id": "lookGit.changesView.remote", "label": "Remote" },
      { "id": "lookGit.changesView.stash", "label": "Stash" },
      { "id": "lookGit.changesView.tags", "label": "Tags" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "look-git",
          "title": "Look Git",
          "icon": "resources/look-git-icon.svg"
        }
      ]
    },
    "views": {
      "look-git": [
        {
          "id": "lookGit.commitHistory",
          "name": "Commit History",
          "icon": "resources/look-git-icon.svg",
          "contextualTitle": "Look Git"
        },
        {
          "id": "lookGit.graphView",
          "name": "Git Graph",
          "type": "webview",
          "contextualTitle": "Look Git"
        },
        {
          "id": "lookGit.changesView",
          "name": "Changes",
          "type": "webview",
          "contextualTitle": "Look Git"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "lookGit.commitHistory",
        "contents": "No Git repository found.\n[Open a folder with a Git repository](command:vscode.openFolder)",
        "when": "!lookGit.hasRepository"
      },
      {
        "view": "lookGit.changesView",
        "contents": "No Git repository found.\n[Open a folder with a Git repository](command:vscode.openFolder)",
        "when": "!lookGit.hasRepository"
      }
    ],
    "commands": [
      {
        "command": "lookGit.refreshHistory",
        "title": "Refresh Commit History",
        "category": "Look Git",
        "icon": "$(refresh)"
      },
      {
        "command": "lookGit.loadMore",
        "title": "Load More Commits",
        "category": "Look Git",
        "icon": "$(ellipsis)"
      },
      {
        "command": "lookGit.cherryPick",
        "title": "Cherry-pick Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.rebase",
        "title": "Rebase onto Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.reset",
        "title": "Reset to Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.revert",
        "title": "Revert Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.drop",
        "title": "Drop Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.renameCommit",
        "title": "Edit Commit Message",
        "category": "Look Git"
      },
      {
        "command": "lookGit.checkout",
        "title": "Checkout Revision",
        "category": "Look Git"
      },
      {
        "command": "lookGit.squash",
        "title": "Squash Commits",
        "category": "Look Git"
      },
      {
        "command": "lookGit.fixup",
        "title": "Fixup Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.pushUpTo",
        "title": "Push All Up To Here",
        "category": "Look Git"
      },
      {
        "command": "lookGit.copyCommitHash",
        "title": "Copy Commit Hash",
        "category": "Look Git"
      },
      {
        "command": "lookGit.viewCommitDetails",
        "title": "View Commit Details",
        "category": "Look Git"
      },
      {
        "command": "lookGit.openGraph",
        "title": "Open Git Graph",
        "category": "Look Git",
        "icon": "$(git-branch)"
      },
      {
        "command": "lookGit.refreshChanges",
        "title": "Refresh Changes",
        "category": "Look Git",
        "icon": "$(refresh)"
      },
      {
        "command": "lookGit.fetchAll",
        "title": "Fetch All Remotes",
        "category": "Look Git",
        "icon": "$(cloud-download)"
      },
      {
        "command": "lookGit.pull",
        "title": "Pull",
        "category": "Look Git",
        "icon": "$(arrow-down)"
      },
      {
        "command": "lookGit.push",
        "title": "Push",
        "category": "Look Git",
        "icon": "$(arrow-up)"
      },
      {
        "command": "lookGit.stageAll",
        "title": "Stage All Changes",
        "category": "Look Git"
      },
      {
        "command": "lookGit.unstageAll",
        "title": "Unstage All Changes",
        "category": "Look Git"
      },
      {
        "command": "lookGit.discardAll",
        "title": "Discard All Changes",
        "category": "Look Git"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "lookGit.refreshHistory",
          "when": "view == lookGit.commitHistory",
          "group": "navigation"
        },
        {
          "command": "lookGit.openGraph",
          "when": "view == lookGit.commitHistory || view == lookGit.graphView",
          "group": "navigation"
        },
        {
          "command": "lookGit.refreshChanges",
          "when": "view == lookGit.changesView",
          "group": "navigation@5"
        },
        {
          "command": "lookGit.fetchAll",
          "when": "view == lookGit.changesView",
          "group": "navigation@1"
        },
        {
          "command": "lookGit.pull",
          "when": "view == lookGit.changesView",
          "group": "navigation@2"
        },
        {
          "command": "lookGit.push",
          "when": "view == lookGit.changesView",
          "group": "navigation@3"
        },
        {
          "command": "git.pull",
          "when": "view == lookGit.changesView",
          "group": "1_toplevel@1"
        },
        {
          "command": "git.push",
          "when": "view == lookGit.changesView",
          "group": "1_toplevel@2"
        },
        {
          "command": "git.clone",
          "when": "view == lookGit.changesView",
          "group": "1_toplevel@3"
        },
        {
          "command": "git.checkout",
          "when": "view == lookGit.changesView",
          "group": "1_toplevel@4"
        },
        {
          "command": "git.fetch",
          "when": "view == lookGit.changesView",
          "group": "1_toplevel@5"
        },
        {
          "submenu": "lookGit.changesView.commit",
          "when": "view == lookGit.changesView",
          "group": "2_submenus@1"
        },
        {
          "submenu": "lookGit.changesView.changes",
          "when": "view == lookGit.changesView",
          "group": "2_submenus@2"
        },
        {
          "submenu": "lookGit.changesView.pullPush",
          "when": "view == lookGit.changesView",
          "group": "2_submenus@3"
        },
        {
          "submenu": "lookGit.changesView.branch",
          "when": "view == lookGit.changesView",
          "group": "2_submenus@4"
        },
        {
          "submenu": "lookGit.changesView.remote",
          "when": "view == lookGit.changesView",
          "group": "2_submenus@5"
        },
        {
          "submenu": "lookGit.changesView.stash",
          "when": "view == lookGit.changesView",
          "group": "2_submenus@6"
        },
        {
          "submenu": "lookGit.changesView.tags",
          "when": "view == lookGit.changesView",
          "group": "2_submenus@7"
        },
        {
          "command": "git.showOutput",
          "when": "view == lookGit.changesView",
          "group": "9_bottom@1"
        }
      ],
      "view/item/context": [
        {
          "command": "lookGit.cherryPick",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "1_operations@1"
        },
        {
          "command": "lookGit.rebase",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "1_operations@2"
        },
        {
          "command": "lookGit.reset",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "1_operations@3"
        },
        {
          "command": "lookGit.revert",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "1_operations@4"
        },
        {
          "command": "lookGit.checkout",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "1_operations@5"
        },
        {
          "command": "lookGit.drop",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "2_destructive@1"
        },
        {
          "command": "lookGit.renameCommit",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "2_destructive@2"
        },
        {
          "command": "lookGit.squash",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "2_destructive@3"
        },
        {
          "command": "lookGit.fixup",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "2_destructive@4"
        },
        {
          "command": "lookGit.pushUpTo",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "1_operations@6"
        },
        {
          "command": "lookGit.copyCommitHash",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "3_utility@1"
        },
        {
          "command": "lookGit.viewCommitDetails",
          "when": "view == lookGit.commitHistory && viewItem == commit",
          "group": "3_utility@2"
        }
      ],
      "commandPalette": [
        {
          "command": "lookGit.cherryPick",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.rebase",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.reset",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.revert",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.drop",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.renameCommit",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.checkout",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.squash",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.fixup",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.pushUpTo",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.refreshHistory",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.loadMore",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.copyCommitHash",
          "when": "false"
        },
        {
          "command": "lookGit.viewCommitDetails",
          "when": "false"
        },
        {
          "command": "lookGit.openGraph",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.stageAll",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.unstageAll",
          "when": "lookGit.hasRepository"
        },
        {
          "command": "lookGit.discardAll",
          "when": "lookGit.hasRepository"
        }
      ],
      "lookGit.changesView.commit": [
        { "command": "git.commit",                "group": "1_commit@1" },
        { "command": "git.commitStaged",          "group": "1_commit@2" },
        { "command": "git.commitAll",             "group": "1_commit@3" },
        { "command": "git.undoCommit",            "group": "1_commit@4" },
        { "command": "git.rebaseAbort",           "group": "1_commit@5" },
        { "command": "git.commitStagedAmend",     "group": "2_amend@1" },
        { "command": "git.commitAllAmend",        "group": "2_amend@2" },
        { "command": "git.commitStagedSignedOff", "group": "3_signoff@1" },
        { "command": "git.commitAllSignedOff",    "group": "3_signoff@2" }
      ],
      "lookGit.changesView.changes": [
        { "command": "lookGit.stageAll",   "group": "1_changes@1" },
        { "command": "lookGit.unstageAll", "group": "1_changes@2" },
        { "command": "lookGit.discardAll", "group": "1_changes@3" }
      ],
      "lookGit.changesView.pullPush": [
        { "command": "git.sync",        "group": "1_sync@1" },
        { "command": "git.pull",        "group": "2_pull@1" },
        { "command": "git.pullRebase",  "group": "2_pull@2" },
        { "command": "git.pullFrom",    "group": "2_pull@3" },
        { "command": "git.push",        "group": "3_push@1" },
        { "command": "git.pushForce",   "group": "3_push@2" },
        { "command": "git.pushTo",      "group": "3_push@3" },
        { "command": "git.pushToForce", "group": "3_push@4" },
        { "command": "git.fetch",       "group": "4_fetch@1" },
        { "command": "git.fetchPrune",  "group": "4_fetch@2" },
        { "command": "git.fetchAll",    "group": "4_fetch@3" }
      ],
      "lookGit.changesView.branch": [
        { "command": "git.merge",        "group": "1_merge@1" },
        { "command": "git.rebase",       "group": "1_merge@2" },
        { "command": "git.branch",       "group": "2_create@1" },
        { "command": "git.branchFrom",   "group": "2_create@2" },
        { "command": "git.renameBranch", "group": "3_manage@1" },
        { "command": "git.deleteBranch", "group": "3_manage@2" },
        { "command": "git.publish",      "group": "3_manage@3" }
      ],
      "lookGit.changesView.remote": [
        { "command": "git.addRemote",    "group": "1_remote@1" },
        { "command": "git.removeRemote", "group": "1_remote@2" }
      ],
      "lookGit.changesView.stash": [
        { "command": "git.stash",                 "group": "1_stash@1" },
        { "command": "git.stashIncludeUntracked", "group": "1_stash@2" },
        { "command": "git.stashStaged",           "group": "1_stash@3" },
        { "command": "git.stashApplyLatest",      "group": "2_apply@1" },
        { "command": "git.stashApply",            "group": "2_apply@2" },
        { "command": "git.stashPopLatest",        "group": "3_pop@1" },
        { "command": "git.stashPop",              "group": "3_pop@2" },
        { "command": "git.stashDrop",             "group": "4_drop@1" },
        { "command": "git.stashDropAll",          "group": "4_drop@2" }
      ],
      "lookGit.changesView.tags": [
        { "command": "git.createTag",  "group": "1_tags@1" },
        { "command": "git.deleteTag",  "group": "1_tags@2" },
        { "command": "git.pushTags",   "group": "1_tags@3" }
      ]
    },
    "configuration": {
      "title": "Look Git",
      "properties": {
        "lookGit.maxCommits": {
          "type": "number",
          "default": 50,
          "description": "Number of commits to load initially in the history view"
        },
        "lookGit.confirmDangerousOperations": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialogs before destructive operations (reset --hard, drop)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0"
  }
}
