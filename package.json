{
  "name": "look-git",
  "displayName": "Look Git",
  "description": "Experimental React-based VS Code extension shell.",
  "version": "0.0.1",
  "publisher": "mathias8dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/look-git-icon.png",
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onCommand:lookGit.helloWorld",
    "onView:lookGit.helloView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "look-git",
          "title": "Look Git",
          "icon": "resources/look-git-icon.svg"
        }
      ]
    },
    "views": {
      "look-git": [
        {
          "id": "lookGit.helloView",
          "name": "Hello World",
          "type": "webview",
          "icon": "resources/look-git-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "lookGit.helloWorld",
        "title": "Hello World",
        "category": "Look Git"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "check-types": "tsc --noEmit",
    "build:extension": "node esbuild.js",
    "build:webview": "vite build",
    "compile:tests": "tsc -p tsconfig.test.json",
    "compile": "npm run check-types && npm run build:webview && npm run build:extension",
    "dev:webview": "vite",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "vite build --watch",
    "package": "npm run check-types && npm run build:webview && node esbuild.js --production",
    "test": "npm run compile && npm run compile:tests",
    "test:integration": "npm run compile && npm run compile:tests && node ./out/tests/integration/runTest.js",
    "test:e2e": "npm run compile && npm run compile:tests && node ./out/tests/e2e/runE2e.js"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0",
    "vite": "^7.2.4"
  }
}
