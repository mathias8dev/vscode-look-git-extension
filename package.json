{
  "name": "look-git",
  "displayName": "Look Git",
  "description": "Experimental React-based VS Code extension shell.",
  "version": "0.0.1",
  "publisher": "mathias8dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/look-git-icon.png",
  "main": "./dist/extension.cjs",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "look-git", "title": "Look Git", "icon": "resources/look-git-icon.svg" }
      ],
      "panel": [
        { "id": "look-git-graph", "title": "Git Graph", "icon": "resources/look-git-icon.svg" }
      ]
    },
    "views": {
      "look-git": [
        { "id": "lookGit.changesView", "name": "Changes", "type": "webview", "icon": "resources/look-git-icon.svg", "contextualTitle": "Look Git" },
        { "id": "lookGit.commitHistory", "name": "Commit History", "icon": "resources/look-git-icon.svg", "contextualTitle": "Look Git" }
      ],
      "look-git-graph": [
        { "id": "lookGit.graphView", "name": "Git Graph", "type": "webview", "icon": "resources/look-git-icon.svg", "contextualTitle": "Git Graph" }
      ]
    },
    "commands": []
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "check-types": "tsc --noEmit",
    "build:extension": "node esbuild.js",
    "build:webview": "vite build",
    "compile": "npm run check-types && npm run build:webview && npm run build:extension",
    "dev:webview": "vite",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "vite build --watch",
    "package": "npm run check-types && npm run build:webview && node esbuild.js --production",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "npm run compile && node ./tests/e2e/runE2e.js",
    "lint": "echo 'lint: TODO add eslint in later phase'"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "@wdio/cli": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "esbuild": "^0.28.0",
    "nanoid": "^5.1.11",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.7",
    "wdio-vscode-service": "^6.1.4",
    "zustand": "^5.0.14"
  }
}
