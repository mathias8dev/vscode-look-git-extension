{
  "name": "look-git",
  "displayName": "Look Git",
  "description": "Experimental React-based VS Code extension shell.",
  "version": "0.0.1",
  "publisher": "mathias8dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/look-git-icon.png",
  "main": "./dist/extension.cjs",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "look-git",
          "title": "Look Git",
          "icon": "resources/look-git-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "look-git-graph",
          "title": "Git Graph",
          "icon": "resources/look-git-icon.svg"
        }
      ]
    },
    "views": {
      "look-git": [
        {
          "id": "lookGit.changesView",
          "name": "Changes",
          "type": "webview",
          "icon": "resources/look-git-icon.svg",
          "contextualTitle": "Look Git"
        },
        {
          "id": "lookGit.commitHistory",
          "name": "Commit History",
          "type": "webview",
          "icon": "resources/look-git-icon.svg",
          "contextualTitle": "Look Git"
        }
      ],
      "look-git-graph": [
        {
          "id": "lookGit.graphView",
          "name": "Git Graph",
          "type": "webview",
          "icon": "resources/look-git-icon.svg",
          "contextualTitle": "Git Graph"
        }
      ]
    },
    "commands": [
      {
        "command": "lookGit.history.copyRevisionNumber",
        "title": "Copy Revision Number",
        "category": "Look Git",
        "icon": "$(copy)"
      },
      {
        "command": "lookGit.history.createPatch",
        "title": "Create Patch...",
        "category": "Look Git",
        "icon": "$(diff-added)"
      },
      {
        "command": "lookGit.history.cherryPick",
        "title": "Cherry-Pick",
        "category": "Look Git",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "lookGit.history.checkoutRevision",
        "title": "Checkout Revision",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.showRepositoryAtRevision",
        "title": "Show Repository at Revision",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.compareWithLocal",
        "title": "Compare with Local",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.newWorktreeFromCommit",
        "title": "New Branch + Worktree from Here...",
        "category": "Look Git",
        "icon": "$(repo-create)"
      },
      {
        "command": "lookGit.history.compareCommitWithWorktree",
        "title": "Compare Commit with Worktree...",
        "category": "Look Git",
        "icon": "$(compare-changes)"
      },
      {
        "command": "lookGit.history.resetCurrentBranchToHere",
        "title": "Reset Current Branch to Here...",
        "category": "Look Git",
        "icon": "$(discard)"
      },
      {
        "command": "lookGit.history.revertCommit",
        "title": "Revert Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.undoCommit",
        "title": "Undo Commit...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.editCommitMessage",
        "title": "Edit Commit Message...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.fixup",
        "title": "Fixup...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.squashInto",
        "title": "Squash Into...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.dropCommit",
        "title": "Drop Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.interactiveRebaseFromHere",
        "title": "Interactively Rebase from Here...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.pushAllUpToHere",
        "title": "Push All up to Here...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.newBranch",
        "title": "New Branch...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.newTag",
        "title": "New Tag...",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.goToChildCommit",
        "title": "Go to Child Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.goToParentCommit",
        "title": "Go to Parent Commit",
        "category": "Look Git"
      },
      {
        "command": "lookGit.history.openFileDiff",
        "title": "Open Diff",
        "category": "Look Git",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "webview/context": [
        {
          "command": "lookGit.history.copyRevisionNumber",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "1_history_copy@1"
        },
        {
          "command": "lookGit.history.createPatch",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "1_history_copy@2"
        },
        {
          "command": "lookGit.history.cherryPick",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "1_history_copy@3"
        },
        {
          "command": "lookGit.history.checkoutRevision",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "2_history_revision@1"
        },
        {
          "command": "lookGit.history.showRepositoryAtRevision",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "2_history_revision@2"
        },
        {
          "command": "lookGit.history.compareWithLocal",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "2_history_revision@3"
        },
        {
          "command": "lookGit.history.newWorktreeFromCommit",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "2_history_revision@4"
        },
        {
          "command": "lookGit.history.compareCommitWithWorktree",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "2_history_revision@5"
        },
        {
          "command": "lookGit.history.resetCurrentBranchToHere",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "3_history_mutate@1"
        },
        {
          "command": "lookGit.history.revertCommit",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "3_history_mutate@2"
        },
        {
          "command": "lookGit.history.undoCommit",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit' && historyCanUndoCommit",
          "group": "3_history_mutate@3"
        },
        {
          "command": "lookGit.history.editCommitMessage",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "4_history_rewrite@1"
        },
        {
          "command": "lookGit.history.fixup",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "4_history_rewrite@2"
        },
        {
          "command": "lookGit.history.squashInto",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "4_history_rewrite@3"
        },
        {
          "command": "lookGit.history.dropCommit",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "4_history_rewrite@4"
        },
        {
          "command": "lookGit.history.interactiveRebaseFromHere",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "4_history_rewrite@5"
        },
        {
          "command": "lookGit.history.pushAllUpToHere",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "4_history_rewrite@6"
        },
        {
          "command": "lookGit.history.newBranch",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "5_history_refs@1"
        },
        {
          "command": "lookGit.history.newTag",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit'",
          "group": "5_history_refs@2"
        },
        {
          "command": "lookGit.history.goToChildCommit",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit' && historyCanGoToChild",
          "group": "6_history_navigation@1"
        },
        {
          "command": "lookGit.history.goToParentCommit",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyCommit' && historyCanGoToParent",
          "group": "6_history_navigation@2"
        },
        {
          "command": "lookGit.history.openFileDiff",
          "when": "webviewId == 'lookGit.commitHistory' && webviewSection == 'historyFile' && historyFileDiffable",
          "group": "1_history_file@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "check-types": "tsc --noEmit",
    "build:extension": "node esbuild.js",
    "build:webview": "vite build",
    "compile:tests": "tsc -p tsconfig.test.json",
    "compile": "npm run check-types && npm run build:webview && npm run build:extension",
    "dev:webview": "vite",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "vite build --watch",
    "package": "npm run check-types && npm run build:webview && node esbuild.js --production",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "npm run compile && npm run compile:tests && node ./out/tests/integration/runTest.js",
    "test:e2e": "npm run compile && npm run compile:tests && node ./out/tests/e2e/runE2e.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.js\" \"*.mjs\" --max-warnings=0"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify/icons-vscode-icons": "^1.2.29",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "nanoid": "^5.1.11",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.7",
    "zustand": "^5.0.14"
  }
}
