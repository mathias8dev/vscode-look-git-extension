{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node10",
    "outDir": "out",
    "rootDir": ".",
    "types": ["node", "vscode", "@wdio/globals/types", "@wdio/mocha-framework", "expect-webdriverio", "wdio-vscode-service"]
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
