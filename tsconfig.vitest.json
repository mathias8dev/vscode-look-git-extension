{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest"],
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.test.ts",
    "tests/helpers/**/*.ts",
    "tests/mocks/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "dist",
    "out",
    "tests/integration"
  ]
}
